{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "gh-widgets",
  "main": "worker.js",
  "assets": {
    "directory": "./dist"
  },
  "compatibility_date": "2026-07-13",
  "routes": [
    { "pattern": "gh-widgets.hdprajwal.dev", "custom_domain": true }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  }
}
